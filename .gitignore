# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug / loglar
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Windows sistem dosyalari
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*~
*.bak

# Claude Code kisisel ayarlari (paylasilan .claude/settings.json commit edilebilir)
.claude/settings.local.json

# env files (can opt-in for committing if needed)
.env*
!.env.example

# yüklenen görseller — dosyalar sunucuda kalır, repoya girmez
/public/uploads/*
!/public/uploads/.gitkeep

# vercel
.vercel

# turbopack / build onbellegi
.turbo

# typescript
*.tsbuildinfo
next-env.d.ts

